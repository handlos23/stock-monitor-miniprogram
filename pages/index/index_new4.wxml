<!--pages/index/index.wxml-->
<view class="container">
  <view class="header">
    <view class="header-left">
      <view class="menu-container">
        <view class="menu-btn" bindtap="toggleMenu">
          <text class="menu-icon">⚙</text>
        </view>
        <view class="menu-list {{showMenu ? 'show' : ''}}" wx:if="{{userInfo}}">
          <view class="menu-item" bindtap="showUserInfo">
            <text class="menu-item-icon">👤</text>
            <text class="menu-item-text">个人中心</text>
          </view>
          <view class="menu-item" bindtap="subscribeMessage">
            <text class="menu-item-icon">{{isSubscribed ? '🔔' : '📢'}}</text>
            <text class="menu-item-text">{{isSubscribed ? '已订阅' : '订阅提醒'}}</text>
          </view>
          <view class="menu-item" bindtap="logout">
            <text class="menu-item-icon">🚪</text>
            <text class="menu-item-text">退出登录</text>
          </view>
        </view>
      </view>
      <button class="action-btn add-btn" bindtap="toggleAddForm">
        <text class="btn-icon">+</text>
        <text class="btn-text">添加</text>
      </button>
    </view>
    <button class="action-btn refresh-btn" bindtap="refreshStocks">
      <text class="btn-icon">🔄</text>
      <text class="btn-text">刷新</text>
    </button>
  </view>

  <scroll-view
    class="stock-list"
    wx:if="{{stocks.length > 0}}"
    scroll-y="true"
    bindscrolltolower="loadMoreStocks"
    lower-threshold="100"
    enable-back-to-top="true">

    <view class="stock-card" wx:for="{{stocks}}" wx:key="_id" bindtap="editStock" data-id="{{item._id}}">
      <view class="stock-header">
        <view class="stock-basic">
          <text class="stock-name">{{item.name}}</text>
          <text class="stock-code">{{item.code}}</text>
        </view>
        <view class="stock-price-container">
          <text class="stock-price {{item.change >= 0 ? 'up' : 'down'}}">{{item.price}}</text>
          <text class="stock-change {{item.change >= 0 ? 'up' : 'down'}}">
            {{item.change >= 0 ? '+' : ''}}{{item.changePercent}}
          </text>
        </view>
      </view>

      <view class="stock-info">
        <view class="info-row">
          <view class="info-item">
            <text class="info-label">今开</text>
            <text class="info-value {{item.open >= item.yesterdayClose ? 'up' : 'down'}}">{{item.open}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">最高</text>
            <text class="info-value {{item.high >= item.yesterdayClose ? 'up' : 'down'}}">{{item.high}}</text>
          </view>
        </view>
        <view class="info-row">
          <view class="info-item">
            <text class="info-label">最低</text>
            <text class="info-value {{item.low >= item.yesterdayClose ? 'up' : 'down'}}">{{item.low}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">昨收</text>
            <text class="info-value">{{item.yesterdayClose}}</text>
          </view>
        </view>
      </view>

      <view class="threshold-info" wx:if="{{item.buyThreshold || item.sellThreshold}}">
        <view class="threshold-item" wx:if="{{item.buyThreshold}}">
          <text class="threshold-label">买入阈值:</text>
          <text class="threshold-value buy">{{item.buyThreshold}}</text>
        </view>
        <view class="threshold-item" wx:if="{{item.sellThreshold}}">
          <text class="threshold-label">卖出阈值:</text>
          <text class="threshold-value sell">{{item.sellThreshold}}</text>
        </view>
      </view>

      <view class="btn-group">
        <button class="btn btn-danger" catchtap="deleteStock" data-id="{{item._id}}">删除</button>
      </view>
    </view>

    <view class="loading-more" wx:if="{{hasMore && loading}}">
      <text>加载中...</text>
    </view>
    <view class="no-more" wx:if="{{!hasMore}}">
      <text>没有更多了</text>
    </view>
  </scroll-view>

  <view class="empty-state" wx:else>
    <text class="empty-icon">📊</text>
    <text class="empty-text">暂无自选股，请添加</text>
  </view>

  <!-- 添加股票表单 -->
  <view class="add-form-container {{showAddForm ? 'show' : ''}}" wx:if="{{userInfo}}">
    <view class="form-mask" bindtap="toggleAddForm"></view>
    <view class="form-content">
      <view class="form-header">
        <text class="form-title">添加股票</text>
        <text class="form-close" bindtap="toggleAddForm">✕</text>
      </view>
      <view class="form-body">
        <view class="form-item">
          <text class="form-label">股票代码</text>
          <input class="form-input" placeholder="请输入6位股票代码" type="number" maxlength="6" bindinput="onCodeInput" value="{{code}}"/>
        </view>

        <view class="form-item">
          <text class="form-label">股票名称</text>
          <input class="form-input" placeholder="保存时自动获取" disabled value="{{name}}"/>
        </view>

        <view class="form-item">
          <text class="form-label">买入阈值（可选）</text>
          <input class="form-input" placeholder="请输入买入价格" type="digit" bindinput="onBuyThresholdInput" value="{{buyThreshold}}"/>
        </view>

        <view class="form-item">
          <text class="form-label">卖出阈值（可选）</text>
          <input class="form-input" placeholder="请输入卖出价格" type="digit" bindinput="onSellThresholdInput" value="{{sellThreshold}}"/>
        </view>

        <view class="form-item">
          <text class="form-label">备注（可选）</text>
          <textarea class="form-textarea" placeholder="请输入备注信息" bindinput="onRemarkInput" value="{{remark}}"/>
        </view>

        <button class="btn btn-primary" bindtap="addStock">添加股票</button>
      </view>
    </view>
  </view>
</view>
