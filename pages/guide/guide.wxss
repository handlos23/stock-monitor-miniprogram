/* pages/guide/guide.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 40rpx 30rpx;
  text-align: center;
}

.title {
  font-size: 44rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 2rpx;
}

.content {
  padding: 30rpx;
}

.intro-card {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 48rpx 40rpx;
  text-align: center;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.intro-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.intro-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.intro-desc {
  display: block;
  font-size: 28rpx;
  color: #8c8c8c;
}

.feature-list {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.feature-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.feature-item:last-child {
  border-bottom: none;
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #e6f7ff 0%, #bae7ff 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.feature-content {
  flex: 1;
}

.feature-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.feature-desc {
  display: block;
  font-size: 26rpx;
  color: #8c8c8c;
}

.sample-section {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 4rpx solid #1890ff;
}

.sample-list {
  display: flex;
  flex-direction: column;
}

.sample-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.sample-item:last-child {
  border-bottom: none;
}

.sample-left {
  display: flex;
  flex-direction: column;
}

.stock-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.stock-code {
  font-size: 24rpx;
  color: #8c8c8c;
}

.sample-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.stock-price {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stock-price.up {
  color: #ff4d4f;
}

.stock-price.down {
  color: #52c41a;
}

.stock-change {
  font-size: 26rpx;
  font-weight: 500;
}

.stock-change.up {
  color: #ff4d4f;
}

.stock-change.down {
  color: #52c41a;
}

.button-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 30rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.4);
}

.explore-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #fff;
  color: #1890ff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: 2rpx solid #1890ff;
}
