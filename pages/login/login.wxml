
<!--pages/login/login.wxml-->
<view class="container">
  <view class="header">
    <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
    <text class="title">股票监测</text>
    <text class="subtitle">实时监控，智能提醒</text>
  </view>

  <!-- 已登录状态 -->
  <view class="user-info" wx:if="{{userInfo}}">
    <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
    <text class="nickname">{{userInfo.nickName}}</text>
    <text class="login-tip-text">您已登录，可以管理自选股</text>
  </view>

  <view class="content">
    <view class="info-box">
      <text class="info-text">欢迎使用股票监测小程序</text>
      <text class="info-desc">您可以先体验功能，登录后享受更多服务：</text>
      <view class="feature-list">
        <view class="feature-item">
          <text class="feature-icon">✓</text>
          <text class="feature-text">添加自选股</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">✓</text>
          <text class="feature-text">设置价格阈值</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">✓</text>
          <text class="feature-text">接收价格提醒</text>
        </view>
      </view>
    </view>

    <view class="button-group">
      <button class="login-btn" wx:if="{{!userInfo}}" bindtap="handleLogin">微信登录</button>
      <button class="index-btn" wx:if="{{userInfo}}" bindtap="goToIndex">返回首页</button>
    </view>
  </view>

  <view class="footer">
    <view class="agreement-box">
      <view class="checkbox" bindtap="toggleAgree">
        <text class="checkbox-icon {{agreed ? 'checked' : ''}}">{{agreed ? '✓' : ''}}</text>
        <text class="agreement-text">我已阅读并同意</text>
        <text class="agreement-link" bindtap="showUserAgreement">《用户协议》</text>
        <text class="agreement-text">和</text>
        <text class="agreement-link" bindtap="showPrivacyPolicy">《隐私政策》</text>
      </view>
      <text class="tip-text">您可以先浏览功能，再选择是否登录</text>
    </view>
  </view>
</view>
