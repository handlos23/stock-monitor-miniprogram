
<!--pages/login/login.wxml-->
<view class="container">
  <view class="header">
    <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
    <text class="title">股票监测</text>
    <text class="subtitle">实时监控，智能提醒</text>
  </view>

  <view class="content">
    <view class="info-box">
      <text class="info-text">欢迎使用股票监测小程序</text>
      <text class="info-desc">登录后您可以：</text>
      <view class="feature-list">
        <view class="feature-item">
          <text class="feature-icon">✓</text>
          <text class="feature-text">添加自选股</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">✓</text>
          <text class="feature-text">设置价格阈值</text>
        </view>
        <view class="feature-item">
          <text class="feature-icon">✓</text>
          <text class="feature-text">接收价格提醒</text>
        </view>
      </view>
    </view>

    <view class="button-group">
      <button class="login-btn" bindtap="getUserInfo">微信登录</button>
      <button class="register-btn" bindtap="goToRegister">注册账号</button>
    </view>
  </view>

  <view class="footer">
    <text class="agreement">登录即表示同意《用户协议》和《隐私政策》</text>
  </view>
</view>
