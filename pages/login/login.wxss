
/* pages/login/login.wxss */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  min-height: 100vh;
  padding: 100rpx 40rpx;
  box-sizing: border-box;
  background: linear-gradient(180deg, #e6f7ff 0%, #ffffff 100%);
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 40rpx;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 40rpx 0;
  padding: 40rpx;
  background-color: #fff;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-bottom: 20rpx;
  border: 4rpx solid #e6f7ff;
}

.nickname {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.login-tip-text {
  font-size: 26rpx;
  color: #8c8c8c;
}

.logo {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 40rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.2);
}

.title {
  font-size: 52rpx;
  font-weight: bold;
  color: #1890ff;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #999;
}

.content {
  width: 100%;
  margin-top: 60rpx;
}

.info-box {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 48rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 60rpx;
}

.info-text {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.info-desc {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}

.feature-list {
  margin-top: 30rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.feature-icon {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 50%;
  background-color: #e6f7ff;
  color: #1890ff;
  margin-right: 20rpx;
  font-size: 24rpx;
}

.feature-text {
  font-size: 28rpx;
  color: #666;
}

.button-group {
  width: 100%;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 30rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.4);
}

.logout-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: linear-gradient(135deg, #ff4d4f 0%, #cf1322 100%);
  color: #fff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 30rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(255, 77, 79, 0.3);
}

.index-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #fff;
  color: #1890ff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: 2rpx solid #1890ff;
}

.login-btn::after {
  border: none;
}

.register-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background-color: #fff;
  color: #1890ff;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: 2rpx solid #1890ff;
}

.register-btn::after {
  border: none;
}

.footer {
  margin-bottom: 40rpx;
}

.agreement {
  font-size: 24rpx;
  color: #999;
  display: block;
  text-align: center;
  margin-bottom: 12rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #1890ff;
  display: block;
  text-align: center;
}
