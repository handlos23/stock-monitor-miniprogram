/* pages/agreement/agreement.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: 40rpx;
}

.header {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(24, 144, 255, 0.2);
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 1rpx;
}

.content {
  background-color: #fff;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
}

.content h3 {
  font-size: 32rpx;
  font-weight: bold;
  color: #1890ff;
  margin: 32rpx 0 16rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #e6f7ff;
}

.content p {
  margin: 16rpx 0;
  color: #666;
  text-indent: 2em;
}
