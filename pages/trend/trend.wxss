/* pages/trend/trend.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f7fa;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.header-left {
  display: flex;
  align-items: center;
}

.menu-container {
  position: relative;
}

.menu-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #f5f7fa;
}

.menu-icon {
  font-size: 32rpx;
}

.menu-list {
  position: absolute;
  top: 80rpx;
  left: 0;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.12);
  padding: 16rpx 0;
  min-width: 240rpx;
  opacity: 0;
  visibility: hidden;
  transform: translateY(-10rpx);
  transition: all 0.3s ease;
  z-index: 100;
}

.menu-list.show {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  transition: background-color 0.3s;
}

.menu-item:active {
  background-color: #f5f7fa;
}

.menu-item-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.menu-item-text {
  font-size: 28rpx;
  color: #333;
}

.action-btn {
  display: flex;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 48rpx;
  background-color: #f5f7fa;
  border: none;
  font-size: 28rpx;
  line-height: 1;
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.btn-text {
  font-size: 28rpx;
  color: #333;
}

.trend-list {
  height: calc(100vh - 120rpx);
  padding: 24rpx;
}

.trend-card {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.trend-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.trend-basic {
  display: flex;
  align-items: center;
}

.trend-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a1a;
  margin-right: 16rpx;
}

.trend-code {
  font-size: 26rpx;
  color: #8c8c8c;
}

.trend-price-container {
  text-align: right;
}

.trend-price {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff4d4f;
  display: block;
  line-height: 1.2;
}

.trend-price.up {
  color: #ff4d4f;
}

.trend-price.down {
  color: #52c41a;
}

.trend-change {
  font-size: 28rpx;
  color: #ff4d4f;
  display: block;
  margin-top: 4rpx;
}

.trend-change.up {
  color: #ff4d4f;
}

.trend-change.down {
  color: #52c41a;
}

.trend-chart-container {
  width: 100%;
  height: 300rpx;
  margin-bottom: 24rpx;
  background-color: #f5f7fa;
  border-radius: 12rpx;
  overflow: hidden;
}

.trend-chart {
  width: 100%;
  height: 100%;
}

.trend-info {
  display: flex;
  flex-direction: column;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.info-label {
  font-size: 22rpx;
  color: #8c8c8c;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 30rpx;
  font-weight: 500;
  color: #1a1a1a;
  letter-spacing: 0.5rpx;
}

.info-value.up {
  color: #ff4d4f;
}

.info-value.down {
  color: #52c41a;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 240rpx;
}

.empty-icon {
  font-size: 140rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 30rpx;
  color: #8c8c8c;
  letter-spacing: 0.5rpx;
}
